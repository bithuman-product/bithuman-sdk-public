# bitHuman Essence Self-Hosted
# Copy this file: cp .env.example .env

# ── Required ─────────────────────────────────────────────────
BITHUMAN_API_SECRET=your_api_secret_here    # Get from: www.bithuman.ai > Developer
OPENAI_API_KEY=sk-your_openai_key_here      # For AI conversation (agent.py, conversation.py)

# ── Model Path (terminal scripts only, NOT used by Docker) ──
# Docker auto-mounts ./models/ via IMX_MODEL_ROOT in docker-compose.yml
BITHUMAN_MODEL_PATH=./models/avatar.imx     # For quickstart.py, microphone.py, conversation.py

# ── Optional ─────────────────────────────────────────────────
OPENAI_VOICE=coral                          # OpenAI TTS voice
