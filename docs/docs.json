{
  "$schema": "https://mintlify.com/docs.json",
  "name": "bitHuman",
  "theme": "mint",
  "logo": {
    "light": "/images/bithuman-logo.png",
    "dark": "/images/bithuman-logo.png",
    "href": "https://bithuman.ai"
  },
  "favicon": "/images/bitHuman-logo-circle.png",
  "colors": {
    "primary": "#ea5455",
    "light": "#ff7b7c",
    "dark": "#ea5455"
  },
  "navbar": {
    "links": [
      {
        "label": "Downloads",
        "href": "https://releases.bithuman.ai"
      },
      {
        "label": "Pricing",
        "href": "https://docs.bithuman.ai/getting-started/pricing"
      },
      {
        "label": "Changelog",
        "href": "https://docs.bithuman.ai/changelog"
      },
      {
        "label": "Discord",
        "href": "https://discord.gg/ES953n7bPA"
      },
      {
        "label": "Status",
        "href": "https://status.bithuman.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://www.bithuman.ai/#explore"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/bithuman-product/bithuman-sdk-public",
          "icon": "github"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/ES953n7bPA",
          "icon": "discord"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "getting-started/quickstart",
              "getting-started/models",
              "getting-started/authentication",
              "getting-started/pricing"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "getting-started/cli",
              "sdks/python",
              "sdks/swift",
              "sdks/kotlin",
              "integrations/flutter"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/overview",
              "examples/cli-hello",
              "examples/python-hello",
              "examples/swift-ios-hello",
              "examples/kotlin-android-hello",
              "examples/ai-conversation"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/building-avatars",
              "guides/deployment"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "getting-started/architecture",
              "getting-started/device-matrix"
            ]
          },
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/rate-limits",
              "api-reference/errors"
            ]
          },
          {
            "group": "Agents",
            "pages": [
              "api-reference/agent-generation",
              "api-reference/agent-management",
              "api-reference/agent-context"
            ]
          },
          {
            "group": "Assets",
            "pages": [
              "api-reference/file-upload",
              "api-reference/dynamics"
            ]
          }
        ]
      }
    ]
  },
  "openapi": "api-reference/openapi.yaml",
  "api": {
    "baseUrl": "https://api.bithuman.ai",
    "auth": {
      "method": "key",
      "name": "api-secret"
    }
  },
  "feedback": {
    "thumbRating": true
  },
  "seo": {
    "metatags": {
      "og:site_name": "bitHuman Docs",
      "og:type": "website",
      "og:image": "https://docs.bithuman.ai/images/bithuman-banner.jpg",
      "twitter:card": "summary_large_image",
      "twitter:site": "@bithuman_ai",
      "twitter:image": "https://docs.bithuman.ai/images/bithuman-banner.jpg",
      "keywords": "AI avatar SDK, on-device avatar, real-time lip sync, talking avatar API, edge AI avatar, private avatar runtime, conversational AI avatar, cross-platform avatar SDK, bithuman"
    },
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bithuman-product/bithuman-sdk-public",
      "discord": "https://discord.gg/ES953n7bPA"
    }
  },
  "redirects": [
    { "source": "/python-sdk", "destination": "/sdks/python" },
    { "source": "/python-sdk/overview", "destination": "/sdks/python" },
    { "source": "/python-sdk/quickstart", "destination": "/sdks/python" },
    { "source": "/getting-started/quickstart-python", "destination": "/sdks/python" },
    { "source": "/platform", "destination": "/api-reference/overview" },
    { "source": "/swift-sdk", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/overview", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/quickstart", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/streaming", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/essence", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/macos", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/ios", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/troubleshooting", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/cookbook", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/agentic", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/index", "destination": "/sdks/swift" },
    { "source": "/swift-sdk/cli", "destination": "/getting-started/cli" },
    { "source": "/kotlin-sdk", "destination": "/sdks/kotlin" },
    { "source": "/kotlin-sdk/overview", "destination": "/sdks/kotlin" },
    { "source": "/kotlin-sdk/quickstart", "destination": "/sdks/kotlin" },
    { "source": "/kotlin-sdk/streaming", "destination": "/sdks/kotlin" },
    { "source": "/getting-started/install", "destination": "/" },
    { "source": "/getting-started/choose-your-sdk", "destination": "/" },
    { "source": "/getting-started/platforms", "destination": "/getting-started/device-matrix" },
    { "source": "/getting-started/networking-and-offline", "destination": "/getting-started/architecture" },
    { "source": "/getting-started/use-cases", "destination": "/" },
    { "source": "/getting-started/prompts", "destination": "/guides/building-avatars" },
    { "source": "/getting-started/media-guide", "destination": "/guides/building-avatars" },
    { "source": "/getting-started/animal-mode", "destination": "/guides/building-avatars" },
    { "source": "/getting-started/how-it-works", "destination": "/getting-started/models" },
    { "source": "/deployment/avatar-sessions", "destination": "/guides/deployment" },
    { "source": "/deployment/livekit-cloud-plugin", "destination": "/guides/deployment" },
    { "source": "/deployment/self-hosted-gpu", "destination": "/guides/deployment" },
    { "source": "/integrations/embed", "destination": "/guides/deployment" },
    { "source": "/integrations/webhooks", "destination": "/guides/deployment" },
    { "source": "/integrations/events", "destination": "/guides/deployment" },
    { "source": "/examples/audio-clip", "destination": "/examples/python-hello" },
    { "source": "/examples/microphone", "destination": "/examples/python-hello" },
    { "source": "/examples/apple-local", "destination": "/examples/overview" },
    { "source": "/examples/apple-expression", "destination": "/examples/overview" },
    { "source": "/examples/halo-macos", "destination": "/examples/overview" },
    { "source": "/examples/raspberry-pi", "destination": "/examples/overview" },
    { "source": "/examples/self-hosted-plugin", "destination": "/guides/deployment" },
    { "source": "/quickstart", "destination": "/getting-started/quickstart" },
    { "source": "/install", "destination": "/" },
    { "source": "/cli", "destination": "/getting-started/cli" }
  ]
}
